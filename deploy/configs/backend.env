# ─── RMASC FACTORY — Backend Production (Déploiement) ───────────────────
# Déploiement sur le serveur factory 192.168.1.95
# MongoDB auto-hébergé — Cloudflare Tunnel vers sarl-rmasc.com

# ── MongoDB (local) ──────────────────────────────────────────────────────
MONGODB_URI="mongodb://127.0.0.1:27017/rmasc-erp"
DATABASE_URL="${MONGODB_URI}"

# ── Authentification ─────────────────────────────────────────────────────
JWT_SECRET="rmasc-jwt-production-secret-2026"
PORT=4000

# ── Webhooks ─────────────────────────────────────────────────────────────
WEBHOOK_API_KEY="rmasc-webhook-shared-secret"
STAMP_HMAC_KEY="rmasc-stamp-signing-key-v1"

# ── Environnement ────────────────────────────────────────────────────────
NODE_ENV=production
