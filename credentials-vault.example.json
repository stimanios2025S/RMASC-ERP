{
  "// ═══════════════════════════════════════════════════════════════════════": "",
  "//  RMASC FACTORY — SYSTEM CREDENTIALS & IDENTIFIERS REGISTRY": "",
  "//  Ce fichier documente toutes les variables de configuration requises.": "",
  "//  Copiez-le en credentials-vault.json et remplissez les valeurs reelles.": "",
  "//  Ne commitez JAMAIS credentials-vault.json dans le depot Git.": "",
  "// ═══════════════════════════════════════════════════════════════════════": "",

  "_instructions": {
    "step_1": "Copier ce fichier vers credentials-vault.json",
    "step_2": "Remplacer chaque placeholder par sa valeur de production reelle",
    "step_3": "Verifier que credentials-vault.json est dans .gitignore",
    "step_4": "Ne jamais partager ce fichier par email ou messagerie"
  },

  "database": {
    "_description": "Connexion a la base de donnees MongoDB / PostgreSQL",

    "mongodb": {
      "uri": "mongodb+srv://<UTILISATEUR>:<MOT_DE_PASSE>@<CLUSTER>.mongodb.net/<NOM_BASE>?retryWrites=true&w=majority",
      "uri_local": "mongodb://localhost:27017/rmasc_erp"
    },

    "postgresql": {
      "DATABASE_URL": "postgresql://<UTILISATEUR>:<MOT_DE_PASSE>@<HOTE>:5432/<NOM_BASE>?pgbouncer=true",
      "DIRECT_URL": "postgresql://<UTILISATEUR>:<MOT_DE_PASSE>@<HOTE>:5432/<NOM_BASE>"
    }
  },

  "authentication": {
    "_description": "Jeton JWT et configuration de la securite des sessions",

    "jwt": {
      "secret": "VOTRE_SECRET_JWT_ALEATOIRE_64_CARACTERES_MINIMUM",
      "expiration": "24h",
      "algorithm": "HS256"
    },

    "bcrypt": {
      "rounds": 12
    }
  },

  "server": {
    "_description": "Configuration du serveur Express et du tunnel Cloudflare",

    "express": {
      "PORT": 4000,
      "HOST": "0.0.0.0",
      "NODE_ENV": "production",
      "trust_proxy": true
    },

    "cors": {
      "origins": [
        "https://sarl-rmasc.com",
        "http://localhost:5173",
        "http://localhost:4173"
      ]
    },

    "cloudflare": {
      "_description": "Parametres du tunnel Cloudflare pour exposition HTTPS publique",
      "tunnel_token": "VOTRE_TOKEN_TUNNEL_CLOUDFLARE",
      "tunnel_name": "rmasc-erp-tunnel",
      "public_hostname": "sarl-rmasc.com"
    }
  },

  "notifications": {
    "_description": "Passerelles de notification tierces (WhatsApp, Email, SMS)",

    "whatsapp": {
      "api_key": "VOTRE_CLE_API_WHATSAPP_BUSINESS",
      "api_url": "https://graph.facebook.com/v18.0/VOTRE_ID_TELEPHONE/messages",
      "admin_phone": "+213550026660"
    },

    "email": {
      "smtp_host": "smtp.gmail.com",
      "smtp_port": 587,
      "smtp_user": "sarl.rmasc@gmail.com",
      "smtp_pass": "VOTRE_MOT_DE_PASSE_APPLICATION_EMAIL"
    }
  },

  "uploads": {
    "_description": "Configuration du stockage des fichiers (dessins CAO, PDF, images)",

    "directory": "backend/uploads",
    "max_file_size_mb": 100,
    "allowed_mime_types": [
      "application/pdf",
      "image/vnd.dxf",
      "image/vnd.dwg",
      "image/png",
      "image/jpeg"
    ]
  },

  "frontend": {
    "_description": "Variables d'environnement du frontend (accessibles via Vite)",

    "VITE_API_BASE_URL": "/api",
    "VITE_APP_TITLE": "RMASC FACTORY ERP",
    "VITE_APP_VERSION": "2.5.3"
  },

  "external_services": {
    "_description": "Services externes et integres (optionnel)",

    "sentry_dsn": "VOTRE_DSN_SENTRY_POUR_LA_SURVEILLANCE_DES_ERREURS",
    "google_analytics_id": "VOTRE_ID_GOOGLE_ANALYTICS"
  },

  "backup": {
    "_description": "Planification des sauvegardes automatiques de la base de donnees",

    "schedule_cron": "0 3 * * *",
    "retention_days": 30,
    "backup_directory": "/var/backups/rmasc-erp"
  }
}
