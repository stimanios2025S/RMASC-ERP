{
  "version": 2,
  "buildCommand": "npx prisma generate --schema=backend/prisma/schema.prisma && npx vite build",
  "outputDirectory": "dist/renderer",
  "installCommand": "npm install",
  "env": {
    "NODE_ENV": "production"
  },
  "functions": {
    "api/index.mjs": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    { "source": "/api/(.*)", "dest": "/api/index.mjs" },
    { "source": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
