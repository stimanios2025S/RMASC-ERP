# ─── RMASC FACTORY — Environnement Variables for Vercel ─────────────────
# Set these in your Vercel project: Settings → Environment Variables

# PostgreSQL (Neon) — REQUIRED
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxx-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxx.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require"

# JWT Secret — REQUIRED
JWT_SECRET="your-random-64-char-secret-here"

# API Port (default 4000, Vercel ignores this)
PORT=4000
