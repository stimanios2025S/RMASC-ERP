# ─── RMASC FACTORY — Vercel Environment Variables ──────────────────────
# Set these in your Vercel project: Settings → Environment Variables

# MongoDB (required — use your Atlas connection string)
MONGODB_URI="mongodb+srv://USER:PASSWORD@cluster.mongodb.net/rmasc-erp?retryWrites=true&w=majority"
DATABASE_URL="${MONGODB_URI}"

# JWT Secret — REQUIRED
JWT_SECRET="your-random-64-char-secret-here"

# External Integrations
WEBHOOK_API_KEY="rmasc-webhook-shared-secret"
STAMP_HMAC_KEY="rmasc-stamp-signing-key-v1"
ELECTRON_APP_URL="http://192.168.0.189:30000/api/integration/receiver"
ELECTRON_SOFTWARE_URL="http://192.168.0.189:30000/api/integration/receiver"
